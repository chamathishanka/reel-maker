# Dependencies
node_modules/

# Generated renders — never commit rendered videos
output/*
!output/.gitkeep

# Per-project media — images & audio stay local, only slides.json is tracked
projects/**/images/
projects/**/audio/
public/projects/

# Per-render / generated project artefacts
**/slides.resolved.json
**/*.waveform.png

# Remotion / bundler caches
.remotion/
**/.cache/

# Logs & runtime
*.log
npm-debug.log*
pids/
*.pid

# Environment / secrets
.env
.env.*
!.env.example

# OS & editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
