# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
# The stock pipeline reads these via server/stock/env.mjs (Node 22 native loader).

# --- Market data ---------------------------------------------------------
# Which provider to use: "finnhub" (default) or "fmp".
STOCK_DATA_PROVIDER=finnhub

# Finnhub free tier — https://finnhub.io/register  (needed for STOCK_DATA_PROVIDER=finnhub)
FINNHUB_API_KEY=

# Financial Modeling Prep free tier — https://site.financialmodelingprep.com/developer/docs
# (only needed if STOCK_DATA_PROVIDER=fmp)
FMP_API_KEY=

# --- Script generation (LLM) --------------------------------------------
# Google Gemini free tier — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (default gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# --- Voiceover ----------------------------------------------------------
# Engine: 'edge' (default, free, unlimited) | 'elevenlabs' (paid plan needed for
# library voices like Charles) | 'piper' (not wired up yet).
# STOCK_TTS_ENGINE=edge

# edge-tts voice (free). Others: en-US-BrianNeural, en-US-EmmaNeural.
STOCK_TTS_VOICE=en-US-AndrewMultilingualNeural

# ElevenLabs (only used when STOCK_TTS_ENGINE=elevenlabs). Free API tier CANNOT
# use library voices — needs Starter+ plan. Get the voice id from the dashboard.
# ELEVENLAB_API_KEY=
# STOCK_ELEVEN_VOICE_ID=
# STOCK_ELEVEN_MODEL=eleven_multilingual_v2   # or eleven_flash_v2_5 (½ credits)

# --- Delivery (LATER — not wired up yet) ---------------------------------
# Telegram handoff is deferred; for now reels land in output/stock/<date>/.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
